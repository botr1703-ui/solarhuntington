# Required for canonical URLs, sitemap, and OG tags
PUBLIC_SITE_URL=https://your-domain.com

# Brand (used in copy + JSON-LD)
PUBLIC_BUSINESS_NAME=Your Service Austin
PUBLIC_PHONE_DISPLAY=(512) 555-0100
PUBLIC_PHONE_TEL=+15125550100
PUBLIC_CITY=Austin
PUBLIC_STATE=TX

# GoHighLevel / form: set to your form POST URL or leave empty to show placeholder
PUBLIC_FORM_ACTION=

# Optional GA4 — Measurement ID (G-XXXXXXXXXX). When set, loads gtag.js and
# fires generate_lead (on /thank-you) + phone_click (tel: links) events.
PUBLIC_GA4_MEASUREMENT_ID=

# Optional Google Search Console verification token (URL-prefix property,
# "HTML tag" method). Renders <meta name="google-site-verification">.
# Leave empty once verified via DNS TXT or via the GA4 tag instead.
PUBLIC_GSC_VERIFICATION=
