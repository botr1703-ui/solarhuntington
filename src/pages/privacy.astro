---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const business = import.meta.env.PUBLIC_BUSINESS_NAME || 'Huntington Solar Co';
const phoneDisplay = import.meta.env.PUBLIC_PHONE_DISPLAY || '(631) 759-8716';
const city = import.meta.env.PUBLIC_CITY || 'Huntington';
const state = import.meta.env.PUBLIC_STATE || 'NY';

const title = `Privacy Policy | ${business}`;
const description = `Privacy policy for ${business} — how we collect, use, and protect information from website visitors and quote requesters.`;
const effective = '2026-05-27';
---

<Layout title={title} description={description} canonicalPath="/privacy/" noindex={true}>
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Privacy policy' },
  ]} />

  <section class="hero">
    <div class="wrap hero-inner">
      <p class="eyebrow">Legal</p>
      <h1>Privacy policy</h1>
      <p class="lead">Effective {effective}.</p>
    </div>
  </section>

  <section class="prose-section">
    <div class="wrap prose-wrap">
      <div class="prose-block">
        <h2>1. What we collect</h2>
        <p>
          When you submit a quote request through this site we collect the information you provide:
          name, address, phone number, email address, and any details about your home or solar
          interest you include in the message. We also automatically collect basic web analytics
          (IP, browser, pages visited, referring URL) via Google Analytics 4.
        </p>
      </div>

      <div class="prose-block">
        <h2>2. How we use it</h2>
        <p>
          We use the information you submit to respond to your quote request, schedule a site visit,
          and prepare your install proposal. We may follow up by phone, text, or email with quote
          updates and answers to questions you ask.
        </p>
        <p>
          We do not sell your personal information to third parties. We do not share it with other
          solar installers. We do not add you to outbound marketing lists without your explicit consent.
        </p>
      </div>

      <div class="prose-block">
        <h2>3. Communications consent</h2>
        <p>
          By submitting a quote request you consent to receiving phone calls, text messages, and
          emails from {business} related to your inquiry. You can opt out of texts at any time by
          replying STOP, and you can opt out of emails using the unsubscribe link in any email we send.
        </p>
      </div>

      <div class="prose-block">
        <h2>4. Cookies and analytics</h2>
        <p>
          We use Google Analytics 4 to understand which pages visitors find useful. Google Analytics
          uses cookies and sets a randomized client identifier — it does not have your name, address,
          or any other personally identifying information.
        </p>
        <p>
          We may use Google Ads conversion tracking and similar attribution pixels (Meta, Microsoft)
          to measure ad effectiveness. These pixels do not retain personally identifying information
          on our end — they retain anonymized conversion events.
        </p>
      </div>

      <div class="prose-block">
        <h2>5. Data retention</h2>
        <p>
          Quote requests are retained as long as you are an active customer or prospect. If you
          ask us to delete your information we delete it within 30 days of the request, except where
          we are required by law (e.g., tax records) or contract (e.g., active install warranty) to
          retain it.
        </p>
      </div>

      <div class="prose-block">
        <h2>6. Your rights</h2>
        <p>
          New York residents and visitors covered by other privacy laws (CCPA, GDPR) have the right
          to request a copy of what we hold about them, request correction of inaccurate information,
          and request deletion. To exercise these rights, contact us at the phone number below.
        </p>
      </div>

      <div class="prose-block">
        <h2>7. Contact</h2>
        <p>
          {business}, {city}, {state}. Phone: {phoneDisplay}. We respond to privacy requests within
          5 business days.
        </p>
      </div>
    </div>
  </section>
</Layout>
