---
import Layout from '../../layouts/Layout.astro';
import LeadForm from '../../components/LeadForm.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { areas, services } from '../../config/site';

export function getStaticPaths() {
  return areas.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const area = areas.find((a) => a.slug === slug);
if (!area) throw new Error(`Unknown area: ${slug}`);

const business =
  import.meta.env.PUBLIC_BUSINESS_NAME || 'Huntington Solar Co';
const city = import.meta.env.PUBLIC_CITY || 'Huntington';
const state = import.meta.env.PUBLIC_STATE || 'NY';
const phoneTel = import.meta.env.PUBLIC_PHONE_TEL || '+16317598716';
const phoneDisplay = import.meta.env.PUBLIC_PHONE_DISPLAY || '(631) 759-8716';
const siteUrl =
  import.meta.env.PUBLIC_SITE_URL?.replace(/\/$/, '') || 'https://www.solarhuntington.com';

const pageHeading = `Solar installation in ${area.title}, ${state}`;
const title = slug === 'huntington'
  // 2026-06-30: lead with year-fresh cost/incentive signal — cluster CTR
  // lifts when SERP titles include both the year and the cost frame.
  ? `Huntington Solar Panel Cost & 2026 Incentives | ${business}`
  : `Solar installation in ${area.title}, ${state} | ${business}`;
const description = area.lead
  ? area.lead
  : `Solar installation in ${area.title}, ${state}: 30% federal tax credit + NY incentives, 25-year warranty, free quote. ${business} serves Suffolk County's north shore.`;

const localBusinessLd = {
  '@type': 'LocalBusiness',
  '@id': `${siteUrl}/#business`,
  name: business,
  url: siteUrl,
  telephone: phoneTel,
  areaServed: { '@type': 'City', name: area.title, containedInPlace: { '@type': 'State', name: state } },
  description: `${business} provides solar installation, battery storage, and repair services in ${area.title}, NY.`,
};

const huntingtonFaqLd = slug === 'huntington' ? {
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Huntington NY?',
      acceptedAnswer: { '@type': 'Answer', text: `A typical 6-10 kW residential solar system in Huntington, NY costs $22,000-$32,000 before incentives. After the 30% federal Investment Tax Credit and NY State's 25% residential solar credit (capped at $5,000), most homeowners net $11,000-$18,000 out-of-pocket for an 8 kW system.` },
    },
    {
      '@type': 'Question',
      name: 'How long does a Town of Huntington solar permit take?',
      acceptedAnswer: { '@type': 'Answer', text: `Town of Huntington Building Department solar permits typically take 2-3 weeks for a standard residential roof-mount. The full timeline including Suffolk County Electrical permit and PSEG Long Island interconnection approval is 6-10 weeks.` },
    },
    {
      '@type': 'Question',
      name: 'Does PSEG Long Island net metering apply in Huntington?',
      acceptedAnswer: { '@type': 'Answer', text: `Yes. Huntington is in the PSEG Long Island service territory, which offers full retail net metering for residential solar systems up to 25 kW. Every kWh your panels export credits a kWh you draw from the grid at the full retail rate on your monthly PSEG bill.` },
    },
  ],
} : null;

const jsonLd: Record<string, unknown> = huntingtonFaqLd
  ? { '@context': 'https://schema.org', '@graph': [localBusinessLd, huntingtonFaqLd] }
  : { '@context': 'https://schema.org', ...localBusinessLd };

// Related: surface 3 services on every location page so visitors who
// landed via a town query can quickly see what we install.
const featuredServices = services.slice(0, 3);
// Cross-link to neighboring locations.
const otherAreas = areas.filter((a) => a.slug !== slug).slice(0, 5);

// Services that have a matrix page for this specific area — surface them
// as town-specific deep links so visitors can pivot from "what we install
// in your town" to the long-form town+service variant.
const HAS_MATRIX = new Set(['battery-storage', 'residential-solar-installation']);
const matrixServices = services.filter((s) => HAS_MATRIX.has(s.slug));
---

<Layout
  title={title}
  description={description}
  canonicalPath={`/locations/${slug}/`}
  jsonLd={jsonLd}
>
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Locations', href: `/locations/${areas[0].slug}/` },
    { label: area.title },
  ]} />

  <section class="hero">
    <div class="wrap hero-inner">
      <p class="eyebrow">{business} · Serving {area.title}, {state}</p>
      <h1>{pageHeading}</h1>
      <p class="lead">{description}</p>
      {area.localStats && <p class="local-stats">{area.localStats}</p>}
      <div class="hero-ctas">
        <a class="btn btn-primary" href="#contact">Get a free quote</a>
        <a class="btn btn-ghost" href={`tel:${phoneTel}`}>Call {phoneDisplay}</a>
      </div>
    </div>
  </section>

  <section class="prose-section">
    <div class="wrap">
      <img
        src="https://images.unsplash.com/photo-1521618755572-156ae0cdd74d?w=1400&q=80&auto=format&fit=crop"
        alt={"Solar panel installation in " + area.title + ", " + state}
        loading="lazy"
        style="width:100%;height:auto;display:block;border-radius:8px;"
      />
    </div>
  </section>

  {area.bodySections && area.bodySections.length > 0 && (
    <section class="prose-section">
      <div class="wrap">
        {area.bodySections.map((sect) => (
          <article class="prose-block">
            <h2>{sect.heading}</h2>
            {sect.paragraphs.map((p) => <p>{p}</p>)}
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="services">
    <div class="wrap">
      <p class="section-eyebrow">What we install</p>
      <h2>Residential, commercial, battery storage — across {area.title} and Suffolk County.</h2>
      <div class="grid grid-services">
        {featuredServices.map((s) => (
          <article class="svc-card">
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <a class="svc-link" href={`/services/${s.slug}/`}>Learn more</a>
          </article>
        ))}
      </div>

      {matrixServices.length > 0 && (
        <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(0,0,0,.08);">
          <p class="section-eyebrow">{area.title}-specific guides</p>
          <h3>Detailed install info for {area.title}, NY</h3>
          <div class="grid grid-services" style="margin-top: 1.5rem;">
            {matrixServices.map((s) => (
              <article class="svc-card">
                <h4 style="margin: 0 0 .5rem;">{s.title} in {area.title}</h4>
                <p style="opacity: .8;">Local permit office, install timeline, and {area.title}-specific incentive math.</p>
                <a class="svc-link" href={`/services/${s.slug}/${area.slug}/`}>View {area.title} details</a>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <section id="contact" class="contact">
    <div class="wrap contact-grid">
      <div class="contact-copy">
        <p class="section-eyebrow">Get your free quote</p>
        <h2>{area.title} solar — tell us your LIPA bill.</h2>
        <p class="contact-lead">
          We use your actual kWh usage to size a system, model the federal and NY state credits,
          and project the payback period. Same business day. No salesperson visit required to
          see the number.
        </p>
        <p class="contact-call">
          Want to talk first? <a href={`tel:${phoneTel}`}>Call {phoneDisplay}</a>
        </p>
      </div>
      <div class="contact-form">
        <LeadForm />
      </div>
    </div>
  </section>

  {area.nearbyTowns && area.nearbyTowns.length > 0 && (
    <section class="nearby">
      <div class="wrap">
        <p class="section-eyebrow">We also serve</p>
        <p class="nearby-list">{area.nearbyTowns.join(' · ')}</p>
      </div>
    </section>
  )}

  <section class="related">
    <div class="wrap">
      <h2>Solar across Suffolk County</h2>
      <div class="area-grid">
        {otherAreas.map((a) => (
          <a class="area-chip" href={`/locations/${a.slug}/`}>
            <span class="area-name">{a.title}</span>
            <span class="area-link">Solar in {a.title}</span>
          </a>
        ))}
      </div>

      <h2 style="margin-top: 3.5rem;">Cost, permits, and incentives for {area.title}</h2>
      <div class="related-grid">
        <a class="related-card" href="/incentives/">
          <h3>2026 incentive stack</h3>
          <p>Every credit and rebate a Suffolk County homeowner can stack — line-by-line.</p>
        </a>
        <a class="related-card" href="/insights/solar-permits-town-of-huntington-2026-walkthrough/">
          <h3>Permits walkthrough</h3>
          <p>Town Building Department + Suffolk County Electrical + PSEG interconnection.</p>
        </a>
        <a class="related-card" href="/insights/how-much-does-solar-cost-in-huntington-ny-2026/">
          <h3>What it actually costs</h3>
          <p>$26K → $11K net math for a typical 8 kW north-shore install.</p>
        </a>
        <a class="related-card" href="/process/">
          <h3>From quote to turn-on</h3>
          <p>9-step timeline — most {area.title} installs complete in 7–10 weeks.</p>
        </a>
      </div>

      <p class="muted center"><a href="/">← Back to home</a></p>
    </div>
  </section>
</Layout>
