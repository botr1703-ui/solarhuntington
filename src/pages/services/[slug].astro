---
import Layout from '../../layouts/Layout.astro';
import LeadForm from '../../components/LeadForm.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { services, areas } from '../../config/site';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = services.find((s) => s.slug === slug);
if (!service) throw new Error(`Unknown service: ${slug}`);

const business =
  import.meta.env.PUBLIC_BUSINESS_NAME || 'Huntington Solar Co';
const city = import.meta.env.PUBLIC_CITY || 'Huntington';
const state = import.meta.env.PUBLIC_STATE || 'NY';
const phoneTel = import.meta.env.PUBLIC_PHONE_TEL || '+16317598716';
const phoneDisplay = import.meta.env.PUBLIC_PHONE_DISPLAY || '(631) 759-8716';
const siteUrl =
  import.meta.env.PUBLIC_SITE_URL?.replace(/\/$/, '') || 'https://www.solarhuntington.com';

const pageHeading = service.pageHeading || `${service.title} in ${city}, ${state}`;
const title = service.metaTitle
  ? `${service.metaTitle} | ${business}`
  : `${service.title} in ${city}, ${state} | ${business}`;
const description =
  service.metaDescription || `${service.description} Serving ${city} and Suffolk County's north shore.`;

// Build JSON-LD: Service schema + optional FAQ schema if the service
// page has its own FAQ entries.
const baseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.title} — ${business}`,
  provider: {
    '@type': 'LocalBusiness',
    name: business,
    telephone: phoneTel,
    url: siteUrl,
  },
  areaServed: areas.map((a) => ({ '@type': 'City', name: a.title, containedInPlace: { '@type': 'State', name: state } })),
  description: service.description,
  url: `${siteUrl}/services/${slug}/`,
};
const jsonLd: Record<string, unknown> = service.faq && service.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        baseJsonLd,
        {
          '@type': 'FAQPage',
          mainEntity: service.faq.map((f) => ({
            '@type': 'Question',
            name: f.q,
            acceptedAnswer: { '@type': 'Answer', text: f.a },
          })),
        },
      ],
    }
  : baseJsonLd;

// Related services to link to from the footer of this page (everything
// except the current service).
const relatedServices = services.filter((s) => s.slug !== slug).slice(0, 4);

// Cross-product service × area matrix pages (generated by tools/page-generator/).
// Surface them as "Available in" links so each service page funnels visitors
// into the long-tail area variants. Two services currently have full matrices:
// battery-storage and residential-solar-installation. For other services we
// surface the location pages instead so visitors can still reach their town.
const HAS_MATRIX = new Set(['battery-storage', 'residential-solar-installation']);
const matrixAreas = HAS_MATRIX.has(slug ?? '') ? areas : [];

// 2026-07-04 SEO wave: point extra internal-link equity at
// /locations/huntington/ ("solar huntington" ranks #63) from the two
// most relevant service pages.
const linkHuntingtonLocation = slug === 'residential-solar-installation' || slug === 'free-solar-quote';
---

<Layout
  title={title}
  description={description}
  canonicalPath={`/services/${slug}/`}
  jsonLd={jsonLd}
>
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: service.title },
  ]} />

  <section class="hero">
    <div class="wrap hero-inner">
      <p class="eyebrow">{business} · {city}, {state}</p>
      <h1>{pageHeading}</h1>
      <p class="lead">{service.description}</p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href="#contact">Get a free quote</a>
        <a class="btn btn-ghost" href={`tel:${phoneTel}`}>Call {phoneDisplay}</a>
      </div>
    </div>
  </section>

  {service.photo && (
    <section class="prose-section">
      <div class="wrap">
        <img
          src={service.photo}
          alt={service.title + " — " + city + ", " + state}
          loading="lazy"
          style="width:100%;height:auto;display:block;border-radius:8px;"
        />
      </div>
    </section>
  )}

  {service.bodySections && service.bodySections.length > 0 && (
    <section class="prose-section">
      <div class="wrap">
        {service.bodySections.map((sect) => (
          <article class="prose-block">
            <h2>{sect.heading}</h2>
            {sect.paragraphs.map((p) => <p>{p}</p>)}
          </article>
        ))}
      </div>
    </section>
  )}

  {service.bullets && service.bullets.length > 0 && (
    <section class="bullets-section">
      <div class="wrap">
        <h2>What's included</h2>
        <ul class="check-list">
          {service.bullets.map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </section>
  )}

  {service.faq && service.faq.length > 0 && (
    <section class="faq">
      <div class="wrap">
        <p class="section-eyebrow">FAQ</p>
        <h2>Common questions about {service.title.toLowerCase()}.</h2>
        <div class="faq-list">
          {service.faq.map((f, i) => (
            <details class="faq-item" open={i === 0}>
              <summary>{f.q}</summary>
              <div class="faq-body">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <section id="contact" class="contact">
    <div class="wrap contact-grid">
      <div class="contact-copy">
        <p class="section-eyebrow">Get your free quote</p>
        <h2>Tell us about your project — we'll send back the math.</h2>
        <p class="contact-lead">
          We use your actual usage to size the system, model the federal and NY state credits,
          and project the payback period. Same business day. No salesperson visit required.
        </p>
        <p class="contact-call">
          Want to talk first? <a href={`tel:${phoneTel}`}>Call {phoneDisplay}</a>
        </p>
      </div>
      <div class="contact-form">
        <LeadForm />
      </div>
    </div>
  </section>

  {matrixAreas.length > 0 && (
    <section class="related">
      <div class="wrap">
        <h2>{service.title} by town</h2>
        <p style="margin-bottom: 1.5rem; opacity: .75;">Town-specific install notes, permit office details, and incentive math for each of our service areas.</p>
        <div class="related-grid">
          {matrixAreas.map((a) => (
            <a class="related-card" href={`/services/${slug}/${a.slug}/`}>
              <h3>{service.shortTitle || service.title} in {a.title}</h3>
              <p>{a.title}, NY — local permit office, typical install timeline, area-specific incentive math.</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="related">
    <div class="wrap">
      <h2>Other services we offer</h2>
      <div class="related-grid">
        {relatedServices.map((s) => (
          <a class="related-card" href={`/services/${s.slug}/`}>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </a>
        ))}
      </div>

      <h2 style="margin-top: 3.5rem;">Pricing, permits, warranties — explained</h2>
      <div class="related-grid">
        {linkHuntingtonLocation && (
          <a class="related-card" href="/locations/huntington/">
            <h3>Solar installation in Huntington, NY</h3>
            <p>Town permit timeline, PSEG net metering, and what we typically install in Huntington.</p>
          </a>
        )}
        <a class="related-card" href="/incentives/">
          <h3>2026 Long Island solar incentives</h3>
          <p>30% federal ITC + 25% NY State + NYSERDA rebate — what each one is and what we file.</p>
        </a>
        <a class="related-card" href="/process/">
          <h3>Our process</h3>
          <p>What happens after you request a quote: 9 steps from initial call to PSEG turn-on.</p>
        </a>
        <a class="related-card" href="/warranty/">
          <h3>Warranty coverage</h3>
          <p>25-year panel performance, 12-year inverter, 10-year workmanship — and what each covers.</p>
        </a>
        <a class="related-card" href="/case-studies/">
          <h3>Real installs</h3>
          <p>Five anonymized Suffolk County installs with line-by-line payback math.</p>
        </a>
      </div>

      <p class="muted center"><a href="/">← Back to home</a></p>
    </div>
  </section>
</Layout>
