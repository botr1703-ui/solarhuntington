---
// Phase 23.11: default to the Forge form-handler worker so a new
// phantom doesn't ship "broken" because PUBLIC_FORM_ACTION wasn't
// set in the env. Override with the env var if you ever want to
// post somewhere else.
const action = import.meta.env.PUBLIC_FORM_ACTION
  || 'https://forge-form-handler.botr1703.workers.dev';
---

<form class="form" method="post" action={action}>
  <input type="hidden" name="_site" value="solarhuntington" />
  <input type="hidden" name="_email_relay" value="info@webtastictech.com" />
  <input type="hidden" name="_cc" value="botr1703@gmail.com" />
  <input type="hidden" name="inquiry_type" value="solar-callback" />
  <input type="hidden" name="_redirect" value="/thank-you/" />
  <input type="text" name="_honeypot" tabindex="-1" autocomplete="off"
         aria-hidden="true"
         style="position:absolute;left:-9999px;opacity:0;pointer-events:none;" />
  <label>
    Name
    <input type="text" name="name" required autocomplete="name" />
  </label>
  <label>
    Phone
    <input type="tel" name="phone" required autocomplete="tel" />
  </label>
  <label>
    Email
    <input type="email" name="email" autocomplete="email" />
  </label>
  <label>
    How can we help?
    <textarea name="message" rows={4} />
  </label>
  <button type="submit">Request a call back</button>
</form>


<script is:inline>
  /* GA4 form-submit reliability pattern.
     2026-06-23 fix: previous handler fired gtag in the submit listener
     without preventing default. The form would navigate to the worker
     before gtag.js had time to flush the beacons, so events never
     reached GA4 (Director dispatch verified zero conversions). New
     flow: capture submit, fire events with event_callback, then submit
     the form once GA confirms (or after a 500ms timeout fallback).
     Avoids dependence on `transport_type: 'beacon'` actually winning
     the race against navigation. */
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('form.form').forEach(function (form) {
      var submitted = false;
      form.addEventListener('submit', function (e) {
        if (submitted) return; /* already in flight from our own form.submit() */
        if (typeof gtag !== 'function') return; /* let form submit normally */

        e.preventDefault();
        function resubmit() {
          if (submitted) return;
          submitted = true;
          form.submit();
        }

        /* Only fire form_submit here. generate_lead is fired ONCE on
           /thank-you/ load — firing it here AND there double-counted
           the conversion in GA4 (caught by dashboard analyzer
           proposal cmqlyemlz, 2026-06-23). */
        gtag('event', 'form_submit', {
          event_category: 'lead',
          event_label: 'solar_callback_form',
          page_path: window.location.pathname,
          transport_type: 'beacon',
          event_callback: resubmit,
          event_timeout: 400,
        });

        /* Belt-and-suspenders: never let the user wait more than 500ms. */
        setTimeout(resubmit, 500);
      });
    });
  });
</script>
